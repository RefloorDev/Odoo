<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="payment_method_bancard" model="payment.method">
            <field name="name">Bancard</field>
            <field name="code">bancard</field>
            <field name="sequence">50</field>
            <field name="active">False</field>
            <field name="image" type="base64" file="payment_bancard/static/src/img/bancard.jpg"/>
            <field name="support_tokenization">False</field>
            <field name="support_express_checkout">False</field>
            <field name="support_refund">partial</field>
        </record>

        <record id="payment_bancard.payment_acquirer_bancard" model="payment.provider">
            <field name="name">International Bancard</field>
            <field name="image_128" type="base64" file="payment_bancard/static/src/img/bancard.jpg"/>
            <field name="code">bancard</field>
            <!-- <field name="display_as">Bancard</field> -->
            <field name="company_id" ref="base.main_company"/>
            <!-- <field name="view_template_id" ref="payment_provider_form_bancard"/> -->
            <!-- <field name="description">
                A payment gateway to accept online payments via bancards.
        </field> -->
            <field name="payment_method_ids" eval="[Command.set([
                         ref('payment_bancard.payment_method_bancard'),
                     ])]" />
        </record>
        <record id="payment_acquirer_authorize" model="payment.provider">
            <field name="name">Authorize.net</field>
            <!-- <field name="display_as">Credit Card (powered by Authorize)</field> -->
            <field name="sequence">3</field>
            <!-- <field name="view_template_id" ref="default_acquirer_button"/> -->
            <field name="image_128" type="base64" file="payment_bancard/static/src/img/authorize_icon.png"/>
            <field name="module_id" ref="base.module_payment_authorize"/>
            <field name="payment_method_ids"
               eval="[Command.set([
                         ref('payment.payment_method_ach_direct_debit'),
                         ref('payment.payment_method_card'),
                     ])]"
        />
            <!-- <field name="description" type="html">
                <p>
