<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<!-- API Configuration form view -->
    <record id="view_api_configuration_form1" model="ir.ui.view">
        <field name="name">dashboard.icons.form</field>
        <field name="model">dashboard.icons</field>
        <field name="arch" type="xml">
            <form string="Dashboard Icons">
                <sheet>
                	<form>
                		<group col="4">
                			<field name="name" />
                            <field name="image_medium" widget="image" class="oe_avatar" /> 
                            <field name="active" />
                            <field name="sequence" />
                            <field name="category" />
                		</group>
                	</form>
                </sheet>
            </form>
        </field>
    </record>

    <!-- API Configuration tree view -->
    <record id="view_api_configuration_tree1" model="ir.ui.view">
        <field name="name">dashboard.icons.tree</field>
        <field name="model">dashboard.icons</field>
        <field name="arch" type="xml">
            <list string="API Configuration">
    			<field name="name" />
            </list>
        </field>
    </record>

    <!-- API Configuration Action view -->
    <record id="action_api_configuration" model="ir.actions.act_window">
        <field name="name">Dashboard Icons</field>
        <field name="res_model">dashboard.icons</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create Configuration.
            </p>
        </field>
    </record>

    <menuitem id="menu_api_configuration_root"
              name="API Configuration"
              parent="base.menu_custom"
              sequence="35" groups="team_api_configuration.dashboard_access_config"/>
    <menuitem
            id="menu_api_configuration"
            action="action_api_configuration"
            parent="menu_api_configuration_root"
            sequence="8" groups="team_api_configuration.dashboard_access_config" />
</odoo>
