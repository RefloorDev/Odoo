<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_company_form_inherit_push_notification" model="ir.ui.view">
            <field name="name">res.company.form.inherit.push.notification</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page name="push_notification" string="Push Notification">
                        <group string="Firebase API Key">
                            <field name="push_api_key_id" nolabel="1"/>
                        </group>
                        <group>
                            <field name="push_api_auth_attachment_id"/>
                            <field name="push_project_id"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>