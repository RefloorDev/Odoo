        <record id="group_hidden_menu" model="res.groups">
            <field name="name">Hidden Menus</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="comment">The user will gain access to the menu which are hidden from normal users.</field>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="team_room_room_comp_rule" model="ir.rule">
            <field name="name">Rooms</field>
            <field name="model_id" ref="model_team_room_room"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

