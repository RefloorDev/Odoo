            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>
        
        <record id="rule_customer_appointmnet" model="ir.rule">
            <field name="name">Customer Appointment</field>
            <field ref="model_team_customer_appointment" name="model_id"/>
            <field name="domain_force">['|',('user_id','=',user.id),('user_id','=',False)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <record id="customer_appointmnet_company_rule" model="ir.rule">
            <field name="name">Appointment Multi-Company</field>
            <field name="model_id" ref="model_team_customer_appointment"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id','child_of',[user.company_id.id])]
            </field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman_all_leads'))]"/>
