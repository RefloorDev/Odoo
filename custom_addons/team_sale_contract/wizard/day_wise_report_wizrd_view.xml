<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="day_wise_report_form" model="ir.ui.view">
            <field name="name">day.wise.sync.status.report.form</field>
            <field name="model">otl.day.wise.sync.status.report</field>
            <field name="arch" type="xml">
                <form string="Sign template model">
                    <group>
                        <group>
                            <field name="date" required="1"/>
                        </group>
                        <group>
                            <field name="name" invisible="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_generate_day_wise_report" string="Generate Report" type="object" class="oe_highlight"/>
                        <field name="report_data" readonly="1" invisible="report_data == False" filename="name"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_day_wise_report" model="ir.actions.act_window">
            <field name="name">Generate Daily Sync Analysis Report</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">otl.day.wise.sync.status.report</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="day_wise_report_form"/>
            <field name="target">new</field>
        </record>

        <menuitem name="Daily Sync Analysis Report" parent="sale.menu_sale_report" id="menu_day_wise_report" action="action_day_wise_report"/>
    </data>
</odoo>
