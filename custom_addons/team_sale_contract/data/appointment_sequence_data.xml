<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequences for sale.order -->
        <record id="seq_customer_appointment" model="ir.sequence">
            <field name="name">Customer Appointments</field>
            <field name="code">team.customer.appointment</field>
            <field name="prefix">CAP/%(range_year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequences for versatile.credit.application -->
        <record id="seq_credit_application" model="ir.sequence">
            <field name="name">Versatile Credit Application</field>
            <field name="code">versatile.credit.application</field>
            <field name="prefix">VCA/%(range_year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>