<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <!-- QUESTIONS -->
    <record model="ir.ui.view" id="quote_question_form">
        <field name="name">Form view for quote question</field>
        <field name="model">team.quote.question</field>
        <field name="arch" type="xml">
            <form string="Quote Question">
                <field name="sequence" invisible="1"/>
                <sheet>
                    <div class="oe_title" style="width: 100%;">
                        <label for="name" string="Question"/>
                        <separator />
                        <field name="name" colspan="4"/>
                        <separator />
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="question_type" widget="radio"/>
                        </group>
                        <group>
                            <div class="col-lg-6 offset-lg-3 o_preview_questions">

                                <!-- Single Line Text Zone -->
                                <div invisible="question_type != 'textbox'">
                                    <i class="fa fa-minus fa-4x" role="img" aria-label="Single Line" title="Single Line"/>
                                </div>
                                <!-- Numerical Value -->
                                <div invisible="question_type != 'numerical_box'">
                                    <i class="fa fa-2x" role="img" aria-label="Numeric" title="Numeric">123..</i>
                                </div>
                                <!-- Multiple choice: only one answer -->
                                <div invisible="question_type != 'simple_choice'" role="img" aria-label="Multiple choice with one answer" title="Multiple choice with one answer">
                                    <div class="row"><i class="fa fa-circle-o  fa-lg"/> answer</div>
                                    <div class="row"><i class="fa fa-dot-circle-o fa-lg"/> answer</div>
                                    <div class="row"><i class="fa fa-circle-o  fa-lg"/> answer</div>
                                </div>
                                <!-- Multiple choice: multiple answers allowed -->
                                <div invisible="question_type != 'multiple_choice'" role="img" aria-label="Multiple choice with multiple answers" title="Multiple choice with multiple answers">
                                    <div class="row"><i class="fa fa-square-o fa-lg"/> answer</div>
                                    <div class="row"><i class="fa fa-check-square-o fa-lg"/> answer</div>
                                    <div class="row"><i class="fa fa-square-o fa-lg"/> answer</div>
                                </div>
                            </div>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="show_in_measurement"/>
                            <field name="show_in_contract"/>
                            <field name="room_ids" widget="many2many_tags" options="{'no_create_edit': True}" required="1"/>
                            <field name="product_category_ids" widget="many2many_tags" options="{'no_create_edit': True}" required="1"/>
                            <field name="default_answer"/>
                            <field name="amount_included"/>
                            <field name="set_default_answer"/>
                            <field name="calculate_order_wise"/>
                            <field name="mandatory_for_current_surface_concrete"/>
                        </group>
                        <group>
                            <field name="reflect_cost"/>
                            <field name="exclude_from_discount"/>
                            <field name="exclude_from_promotion"/>
                            <field name="calculation_type" invisible="reflect_cost != True" required="reflect_cost == True"/>
                            <field name="multiply_with_area" invisible="reflect_cost != True and calculation_type != 'sqft'"/>
                            <field name="differ_cost_based_on_count" invisible="reflect_cost != True or calculation_type != 'unit'"/>
                            <field name="amount" invisible="differ_cost_based_on_count == True and calculation_type == 'unit'"/>
                            <field name="max_allowed_limit"/>
                            <field name="count_cost_line" invisible="differ_cost_based_on_count != True">
                                <list editable="bottom">
                                    <field name="count" required="1"/>
                                    <field name="amount" required="1"/>
                                </list>
                                <form>
                                    <group col="4">
                                        <field name="count" required="1"/>
                                        <field name="amount" required="1"/>
                                    </group>
                                </form>
                            </field>
                            <field name="applicable_rooms" widget="many2many_tags" options="{'no_create_edit': True}" invisible="set_default_answer != True" required="set_default_answer == True"/>
                            <field name="applicable_current_surface" invisible="set_default_answer != True" required="set_default_answer == True"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Answers">
                            <field name="validation_email" invisible="question_type != 'textbox'"/>
                            <label for="validation_email" invisible="question_type != 'textbox'"/>
                            <separator />
                            <!-- context="{'default_question_id': active_id}" this is removed from labels_ids field -->
                            <field name="labels_ids" string="Type of answers" invisible="question_type not in ['simple_choice', 'multiple_choice', 'matrix']" >
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="value" string="Choices"/>
                                    <field name="is_correct"/>
                                    <field name="answer_score"/>
                                </list>
                            </field>
                        </page>
                        <page string="Options">
                            <group string="Constraints">
                                <group colspan="2" col="4">
                                    <field name="constr_mandatory" string="Mandatory Answer"/>
                                    <field name="constr_error_msg" invisible="constr_mandatory == False"/>
                                </group>
                                <div colspan="2" invisible="question_type not in ['textbox', 'numerical_box']">
                                    <group>
                                        <field name="validation_required" invisible="validation_email == True and question_type == 'textbox'"/>
                                    </group>
                                    <group col="4" invisible="validation_required == False">
                                        <field name="validation_length_min" invisible="question_type != 'textbox'"/>
                                        <field name="validation_length_max" invisible="question_type != 'textbox'"/>
                                        <field name="validation_min_float_value" invisible="question_type != 'numerical_box'"/>
                                        <field name="validation_max_float_value" invisible="question_type != 'numerical_box'"/>
                                        <field name="validation_error_msg" colspan="4"/>
                                    </group>
                                </div>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="quote_question_tree">
        <field name="name">Tree view for quote question</field>
        <field name="model">team.quote.question</field>
        <field name="arch" type="xml">
            <list string="Quote Question">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code" column_invisible="1"/>
                <field name="show_in_measurement"/>
                <field name="show_in_contract"/>
                <field name="question_type"/>
            </list>
        </field>
    </record>
    <record model="ir.ui.view" id="quote_question_search">
        <field name="name">Search view for quote question</field>
        <field name="model">team.quote.question</field>
        <field name="arch" type="xml">
            <search string="Search Question">
                <field name="name" string="Question"/>
                <field name="question_type" string="Type"/>
                <group expand="1" string="Group By">
                    <filter name="group_by_type" string="Type" domain="[]"  context="{'group_by':'question_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_quote_question_form">
        <field name="name">Questions</field>
        <field name="res_model">team.quote.question</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="quote_question_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_empty_folder">
            No questions found
          </p>
        </field>
    </record>

    <menuitem name="Questions"
        id="menu_quote_question_form1"
        action="action_quote_question_form"
        parent="measurement_conf_root"
        sequence="50"/>

    </data>
</odoo>
