        <record id="stock_product_search_form_view" model="ir.ui.view">
            <field name="name">product.product.search.stock.form</field>
            <field name="model">product.product</field>
            <field name="mode">primary</field>
            <field name="inherit_id" ref="product.product_search_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='inactive']" position="after">
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Product Template" name="product_template" domain="[]"
                                context="{'group_by':'product_tmpl_id'}"/>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="stock.stock_product_normal_action" model="ir.actions.act_window">
            <field name="name">Product Variants</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="team_sale_contract.stock_product_search_form_view"/>
            <field name="domain">[('type', 'in', ('product', 'consu'))]</field>
            <field name="context">{'search_default_product_template': 1}</field>
        </record>


        <!-- Promo codes -->
        <record id="view_monthly_promo_form" model="ir.ui.view">
            <field name="name">team.monthly.promo.form</field>
            <field name="model">team.monthly.promo</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="image" widget='image' class="oe_avatar"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                attrs="{'invisible': [('active', '=', True)]}"/>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" required="True"/>
                            </h1>
                        </div>
                        <group>
                            <group name="left">
                                <field name="type"/>
                                <field name="attachment_id"/>
                                <field name="company_id" options="{'no_create': True}"
                                       groups="base.group_multi_company"/>
                            </group>
                            <group name="right">
                                <field name="code" required="True"/>
                                <field name="amount"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_monthly_promo_tree" model="ir.ui.view">
            <field name="name">team.monthly.promo.tree</field>
            <field name="model">team.monthly.promo</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="type"/>
                    <field name="amount"/>
                    <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                </tree>
            </field>
        </record>


        <record id="action_monthly_promo" model="ir.actions.act_window">
            <field name="name">Promo Codes</field>
            <field name="res_model">team.monthly.promo</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click here to create a new promo codes.
                </p>
            </field>
        </record>

        <menuitem name="Promo Codes" parent="measurement_conf_root" id="menu_monthly_promo" action="action_monthly_promo"/>

    </data>
</odoo>
