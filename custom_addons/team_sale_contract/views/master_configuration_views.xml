        <record id="product_template_forms" model="ir.ui.view">
            <field name="name">product.template.form</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//page[1]" position="after">
                    <page string="Payment Configuration" name="contract_questions">
                        <group col="4">
                            <field name="payment_plan" required="True"/>
                            <field name="sequence"/>
                            <field name="description" placeholder="Internal Notes..."/>
                            <field name="warranty"/>
                            <field name="active" invisible="1"/>
                            <field name="msrp"/>
                            <field name="unit_of_measure"/>
                            <field name="warranty_info"/>

                        </group>
                        <separator string="Calculation"/>
                        <group col="4">
                            <!--                           <label for="room_area"/>-->
                            <!--                           <div class="o_row" name="room_area">-->
                            <!--                               <field name="room_area" string="Room Area"/>-->
                            <!--                               sq.ft-->
                            <!--                           </div>-->
                            <label for="labor_cost"/>
                            <div class="o_row" name="labor_cost">
                                <field name="labor_cost" string="Labor Charge"/>
                                $/hr
                            </div>
                            <label for="labor_factor"/>
                            <div class="o_row" name="labor_factor">
                                <field name="labor_factor" string="Labor Factor"/>
                            </div>
                            <label for="labor_cost_with_factor"/>
                            <div class="o_row" name="labor_cost_with_factor">
                                <field name="labor_cost_with_factor" string="Labor Cost With Factor"/>
                                sqft
                            </div>
                            <label for="installation_assumption"/>
                            <div class="o_row" name="installation_assumption">
                                <field name="installation_assumption" string="Installation Assumption"/>
                                sq.ft/hr
                            </div>
                            <label for="cost_per_sqft"/>
                            <div class="o_row" name="cost_per_sqft">
                                <field name="cost_per_sqft" string="Labor Cost With Factor per sq.ft"/>
                            </div>
                            <label for="flooring_cost"/>
                            <div class="o_row" name="flooring_cost">
                                <field name="flooring_cost" string="Flooring Cost"/>
                                $/sq.ft
                            </div>
                        </group>
                        <separator string="Discount"/>
                        <group col="4">
                            <label for="monthly_promo"/>
                            <div class="o_row" name="monthly_promo">
                                <field name="monthly_promo" string="Monthly Promo"/>
                                $
                            </div>
                            <label for="discount"/>
                            <div class="o_row" name="discount">
                                <field name="discount" string="Default Discount"/>
                                %
                            </div>
                            <label for="discount_minimum"/>
                            <div class="o_row" name="discount_minimum">
                                <field name="discount_minimum" string="Minimum Discount  Allowed"/>
                                %
                            </div>
                            <label for="discount_maximum"/>
                            <div class="o_row" name="discount_maximum">
                                <field name="discount_maximum" string="Maximum Discount Allowed"/>
                                %
                            </div>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>


