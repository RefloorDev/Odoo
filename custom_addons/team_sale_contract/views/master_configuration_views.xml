        <!-- Floor Levels -->
        <record id="view_floor_level_form" model="ir.ui.view">
            <field name="name">team.floor.level.form</field>
            <field name="model">team.floor.level</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="image" widget='image' class="oe_avatar"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                attrs="{'invisible': [('active', '=', True)]}"/>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" required="True"/>
                            </h1>
                        </div>
                        <group>
                            <group name="left">
                                <field name="prefix"/>
                                <field name="superscript_symbol" attrs="{'required': [('prefix', '!=', '')]}"/>
