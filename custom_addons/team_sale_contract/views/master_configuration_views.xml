<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="res_company_default_image_view_form" model="ir.ui.view">
        <field name="name">res.company.view.form.inherit</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="defaul_image" string="Default Images">
                    <group name="default_image_settings">
                        <field name="default_image" widget="image" class="oe_avatar" invisible="1"/>
                        <field name="material_image_attachment_id"/>
                        <field name="material_image" widget="image" class="oe_avatar"/>
                        <field name="sales_app_attachment_id"/>
                        <field name="sales_app_logo" widget="image" class="oe_avatar"/>
                        <field name="contract_logo_attachment_id"/>
                        <field name="contract_logo" widget="image" class="oe_avatar"/>
                        <field name="login_logo_attachment_id"/>
                        <field name="login_logo" widget="image" class="oe_avatar"/>
                        <field name="promo_image_attachment_id"/>
                        <field name="promo_image" widget="image" class="oe_avatar"/>
                    </group>
                </page>
            </xpath>
            <field name="favicon" position="after">
                <field name="recision_date"/>
            </field>
        </field>
    </record>

        <!--        Measurement Root Menu-->
        <menuitem name="Measurements" parent="sale.menu_sale_config" id="measurement_conf_root"/>

        <!-- Rooms -->
        <record id="view_room_room_form" model="ir.ui.view">
            <field name="name">team.room.room.form</field>
            <field name="model">team.room.room</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="image" widget='image' class="oe_avatar"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                attrs="{'invisible': [('active', '=', True)]}"/>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" required="True"/>
                            </h1>
                        </div>
                        <group>
                            <group name="left">
                                <field name="note" placeholder="Internal notes..."/>
                                <field name="is_custom"/>
                                <field name="company_id" options="{'no_create': True}"
                                       groups="base.group_multi_company"/>
                            </group>
                            <group name="right">
                                <field name="sequence"/>
                                <field name="product_category_id" options="{'no_create': True}"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_room_room_tree" model="ir.ui.view">
            <field name="name">team.room.room.tree</field>
            <field name="model">team.room.room</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="sequence"/>
                    <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                </tree>
            </field>
        </record>


        <record id="action_room_room" model="ir.actions.act_window">
            <field name="name">Rooms</field>
            <field name="res_model">team.room.room</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click here to create a new room.
                </p>
            </field>
        </record>

        <menuitem name="Rooms" parent="measurement_conf_root" id="menu_room" action="action_room_room"/>


        <!-- Floor Shapes -->
        <record id="view_floor_shape_form" model="ir.ui.view">
