<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="team_floor_molding_form_view" model="ir.ui.view">
            <field name="name">team.floor.molding.form.view</field>
            <field name="model">team.floor.molding</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True"/>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" required="True"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="company_id"/>
                                <field name="unit_price"/>
                            </group>
                            <group>
                                <field name="sequence"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="team_floor_molding_list_view" model="ir.ui.view">
            <field name="name">team.floor.molding.list.view</field>
            <field name="model">team.floor.molding</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sequence" widget='handle'/>
                    <field name="name"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="unit_price"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="team_floor_molding_action_window" model="ir.actions.act_window">
            <field name="name">Molding Types</field>
            <field name="res_model">team.floor.molding</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                Create!
                </p>
            </field>
        </record>

        <menuitem name="Molding Types" parent="measurement_conf_root" id="menu_act_molding_types" action="team_floor_molding_action_window"/>
    </data>
</odoo>
