<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_contract_room_measurement_line_form" model="ir.ui.view">
            <field name="name">team.contract.room.measurement.line.form</field>
            <field name="model">team.contract.room.measurement.line</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group col="4">
                            <field name="room_id" options="{'no_open':True,'no_create': True}"/>
                            <field name="custom_room_name" string="Room Name" attrs="{'invisible': [('custom_room_measured', '!=', True)]}"/>
                            <field name="custom_room_measured" invisible="1"/>
                            <field name="adjusted_area" string="Room Area"/>
                            <field name="color_up_charge_price"/>
                            <field name="color_up_charge_total"/>
                            <field name="room_perimeter"/>
                            <field name="molding_unit_price"/>
                            <field name="molding_total_price"/>
                            <field name="exclude_from_calculation"/>
                            <field name="comments"/>
                            <field name="shape_image_id"  invisible="1"/>
                            <field name="material_id" options="{'no_open':True,'no_create': True}" domain="[('improveit_product_id', '!=', False)]"/>
                            <field name="material_comments"/>
                            <field name="molding_type_id" options="{'no_open':True,'no_create': True}"/>
                        </group>
                        <group attrs="{'invisible': [('shape_image_id', '=', False)]}">
                            <group>
                                <field name="shape_image" widget="image" class="oe_avatar" options="{'image_preview': 'image_128'}"/>
                            </group>
                            <group></group>
                        </group>
                        <group string="Transitions">
                            <field name="transition_line_id" readonly="1">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="transition_width"/>
                                    <field name="transition_height"/>
                                </tree>
                                <form>
                                    <group>
                                        <group>
                                            <field name="name"/>
                                        </group>
                                        <group>
                                            <field name="transition_width"/>
                                            <field name="transition_height"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </group>
                        <group string="Room Images" attrs="{'invisible': [('attachment_ids', '=', False)]}">
                            <field nolabel="1" name="attachment_ids">
                                <kanban>
                                    <field name="mimetype"/>
                                    <field name="type"/>
                                    <field name="url"/>
                                    <field name="type"/>
                                    <field name="name"/>
                                    <field name="id"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="oe_kanban_global_area oe_kanban_global_click o_kanban_attachment">
                                                <div class="o_kanban_image">
                                                    <div class="o_kanban_image_wrapper">
                                                        <t t-set="webimage" t-value="new RegExp('image.*(gif|jpeg|jpg|png)').test(record.mimetype.value)"/>
                                                        <div t-if="record.type.raw_value == 'url'" class="o_url_image fa fa-link fa-3x text-muted"/>
                                                        <img t-elif="webimage" t-attf-src="/web/image/#{record.id.raw_value}" width="100" height="100" alt="Document" class="o_attachment_image"/>
                                                        <div t-else="!webimage" class="o_image o_image_thumbnail" t-att-data-mimetype="record.mimetype.value"/>
                                                    </div>
                                                </div>
                                                <div class="o_kanban_details">
                                                    <div class="o_kanban_details_wrapper">
                                                        <div t-att-title="record.name.raw_value" class="o_kanban_record_title">
                                                            <field name="name" class="o_text_overflow"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </group>
                        <group string="Anomaly Images" attrs="{'invisible': [('protrusion_image_ids', '=', False)]}">
                            <field nolabel="1" name="protrusion_image_ids">
                                <kanban>
                                    <field name="mimetype"/>
                                    <field name="type"/>
                                    <field name="url"/>
                                    <field name="type"/>
                                    <field name="name"/>
                                    <field name="id"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="oe_kanban_global_area oe_kanban_global_click o_kanban_attachment">
                                                <div class="o_kanban_image">
                                                    <div class="o_kanban_image_wrapper">
                                                        <t t-set="webimage" t-value="new RegExp('image.*(gif|jpeg|jpg|png)').test(record.mimetype.value)"/>
                                                        <div t-if="record.type.raw_value == 'url'" class="o_url_image fa fa-link fa-3x text-muted"/>
                                                        <img t-elif="webimage" t-attf-src="/web/image/#{record.id.raw_value}" width="100" height="100" alt="Document" class="o_attachment_image"/>
                                                        <div t-else="!webimage" class="o_image o_image_thumbnail" t-att-data-mimetype="record.mimetype.value"/>
                                                    </div>
                                                </div>
                                                <div class="o_kanban_details">
                                                    <div class="o_kanban_details_wrapper">
                                                        <div t-att-title="record.name.raw_value" class="o_kanban_record_title">
                                                            <field name="name" class="o_text_overflow"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_contract_question_line_form" model="ir.ui.view">
            <field name="name">team.contract.question.line.form</field>
            <field name="model">team.contract.question.line</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                        <group col="4">
                            <field name="name"/>
                            <field name="room_id" options="{'no_open':True,'no_create': True}"/>
                            <field name="question_id" options="{'no_open':True,'no_create': True}" required="1"/>
                            <field name="appointment_id" options="{'no_open':True,'no_create': True}"/>
                            <field name="answers">
                                <tree editable="bottom">
                                    <field name="answer"/>
                                </tree>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="sale_contract_question_measurements_lines" model="ir.ui.view">
            <field name="name">sale.order.form.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="priority" eval="20"/>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//button[@name='action_cancel']" position="after">
                        <button name="add_payment_line" string=" Add Payment" type="object" class="oe_highlight"
                                invisible="1"/>
                        <button name="generate_link" string="Share" type="object" class="oe_highlight" invisible="1"/>
                    </xpath>
                    <xpath expr="//field[@name='payment_term_id']" position="after">
                        <field name="floor_type" string="Product Plan" required="0" domain="[('improveit_product_id', '!=', False)]"  options="{'no_open':True,'no_create': True}"/>
                        <field name="link_to_share" widget="url" readonly="1" attrs="{'invisible': [('link_to_share', '=', False)]}"/>
                        <field name="appointment_id" readonly="1" attrs="{'invisible': [('appointment_id', '=', False)]}"/>
                        <field name="quote_id" readonly="1" attrs="{'invisible': [('quote_id', '=', False)]}"/>
                        <field name="excluded_quote_id" readonly="1" attrs="{'invisible': [('excluded_quote_id', '=', False)]}"/>
                        <field name="special_price_id" readonly="1" attrs="{'invisible': [('special_price_id', '=', False)]}"/>
                        <field name="stair_special_price_id" readonly="1" attrs="{'invisible': [('stair_special_price_id', '=', False)]}"/>
                        <field name="min_sale_price" readonly="1" groups="base.group_no_one"/>
                    </xpath>
                    <page name="optional_products" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </page>
                    <page name="customer_signature" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </page>
                    <field name="validity_date" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </field>
                    <field name="payment_term_id" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </field>
                    <field name="amount_tax" position="after">
                        <field name="amount_total_not_rounded" widget='monetary' options="{'currency_field': 'currency_id'}"/>
                    </field>
                    <xpath expr="//page[1]" position="after">
                        <page string="Contract Questions" name="contract_questions">
                            <field name="contract_question_line" widget="one2many_list" mode="tree,kanban"
                                   attrs="{'readonly': [('state', 'not in', ('draft'))]}">
                                <tree>
                                    <field name="room_id" options="{'no_open':True,'no_create': True}"/>
                                    <field name="room_name"/>
                                    <field name="question_id" options="{'no_open':True,'no_create': True}"/>
                                    <field name="answer_data"/>
                                    <field name="extra_price" sum="Total"/>
                                    <field name="appointment_id" invisible="1"/>
                                </tree>
                                <kanban class="o_kanban_mobile">
                                    <field name="name"/>
                                    <field name="room_id"/>
                                    <field name="question_id"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="oe_kanban_card oe_kanban_global_click">
                                                <div class="row">
                                                    <div class="col-12">
                                                        <span>
                                                            Question:
                                                            <t t-esc="record.name.value"/>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-12">
                                                        <span>
                                                            Answer:
                                                            <t t-esc="record.answer_data.value"/>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-12 text-muted">
                                                        <span style="padding-left: 3px;">
                                                            <t t-esc="record.room_id.value"/>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                                <form string="Questions">
                                    <group col="4">
                                        <field name="question_id" options="{'no_open':True,'no_create': True}"/>
                                        <field name="room_id" options="{'no_open':True,'no_create': True}"/>
                                        <field name="room_name"/>
                                        <field name="extra_price"/>
                                        <field name="answers">
                                            <tree editable="bottom">
                                                <field name="answer"/>
                                            </tree>
                                        </field>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Room Measurements" name="room_measurements">
                            <field name="room_measurement_line" widget="one2many_list" mode="tree,kanban"
                                   attrs="{'readonly': [('state', 'not in', ('draft'))]}">
                                <tree>
                                    <field name="room_id" options="{'no_open':True,'no_create': True}"/>
                                    <field name="custom_room_name" string="Room Name"/>
                                    <field name="custom_room_measured" invisible="1"/>
                                    <field name="appointment_id" invisible="1"/>
                                    <field name="adjusted_area"  string="Room Area"/>
                                    <field name="room_perimeter"/>
                                    <field name="color_up_charge_total" sum="Total"/>
                                    <field name="exclude_from_calculation"/>
                                </tree>
                                <kanban class="o_kanban_mobile">
                                    <field name="room_id"/>
                                    <field name="adjusted_area"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="oe_kanban_card oe_kanban_global_click">
                                                <div class="row">
                                                    <div class="col-6">
                                                        <strong>
                                                            <span>
                                                                <t t-esc="record.room_id.value"/>
                                                            </span>
                                                        </strong>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-12">
                                                        <strong>
                                                            <span class="float-right text-right">
                                                                Room Area:
                                                                <t t-esc="record.adjusted_area.value"/>
                                                            </span>
                                                        </strong>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                            <group class="oe_subtotal_footer oe_right" colspan="2" name="totoal_area">
                                <field name="total_area"/>
                            </group>
                        </page>
                        <page string="Room Transitions" name="room_transitions" invisible="1">
                            <field name="room_transition_line" widget="one2many_list" mode="tree,kanban"
                                   attrs="{'readonly': [('state', 'not in', ('draft'))]}">
                                <tree editable="bottom">
                                    <field name="room_id" options="{'no_open':True,'no_create': True}"/>
                                    <field name="name"/>
                                    <field name="transition_width"/>
                                </tree>
                                <kanban class="o_kanban_mobile">
                                    <field name="name"/>
                                    <field name="room_id"/>
                                    <field name="appointment_id" invisible="1"/>
                                    <field name="transition_width"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="row">
                                                <div class="col-8">
                                                    <strong>
                                                        <span>
                                                            <t t-esc="record.name.value"/>
                                                        </span>
                                                    </strong>
                                                </div>
                                                <div class="col-4">
                                                    <strong>
                                                        <span class="float-right text-right">
                                                            <t t-esc="record.transition_width.value"/>
                                                        </span>
                                                    </strong>
                                                </div>
                                            </div>
                                            <div class="row">
                                                <strong>
                                                    <span  style="padding:3px;">
                                                        <t t-esc="record.room_id.value"/>
                                                    </span>
                                                </strong>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                                <form string="Transitions">
                                    <group col="4">
                                        <field name="name"/>
                                        <field name="transition_width"/>
                                        <field name="room_id" options="{'no_open':True,'no_create': True}"/>
                                    </group>
                                    <group string="Transition Images">
                                        <field nolabel="1" name="attachment_ids">
                                            <kanban>
                                                <field name="id"/>
                                                <field name="mimetype"/>
                                                <field name="type"/>
                                                <field name="create_uid"/>
                                                <field name="url"/>
                                                <field name="type"/>
                                                <field name="create_date"/>
                                                <field name="name"/>
                                                <templates>
                                                    <t t-name="kanban-box">
                                                        <div class="oe_kanban_global_area oe_kanban_global_click o_kanban_attachment">
                                                            <div class="o_kanban_image">
                                                                <div class="o_kanban_image_wrapper">
                                                                    <t t-set="webimage" t-value="new RegExp('image.*(gif|jpeg|jpg|png)').test(record.mimetype.value)"/>
                                                                    <div t-if="record.type.raw_value == 'url'" class="o_url_image fa fa-link fa-3x text-muted"/>
                                                                    <img t-elif="webimage" t-attf-src="/web/image/#{record.id.raw_value}" width="100" height="100" alt="Document" class="o_attachment_image"/>
                                                                    <div t-else="!webimage" class="o_image o_image_thumbnail" t-att-data-mimetype="record.mimetype.value"/>
                                                                </div>
                                                            </div>
                                                            <div class="o_kanban_details">
                                                                <div class="o_kanban_details_wrapper">
                                                                    <div t-att-title="record.name.raw_value" class="o_kanban_record_title">
                                                                        <field name="name" class="o_text_overflow"/>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </t>
                                                </templates>
                                            </kanban>
                                        </field>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Progressive Discount History">
                            <group>
                                <field name="discount_history_line" nolabel="1" widget="one2many_list" mode="tree,kanban"
                                   readonly="1">
                                    <tree editable="bottom" string="Discount History">
                                        <field name="name"/>
                                        <field name="type"/>
                                        <field name="promo_type"/>
                                        <field name="actual_price"/>
                                        <field name="excluded_amount_discount"/>
                                        <field name="discount_amount"/>
                                        <field name="sale_price"/>
                                    </tree>
                                    <form string="Discount History">
                                        <group col="4">
                                            <field name="name"/>
                                            <field name="type"/>
                                            <field name="promo_type"/>
                                            <field name="actual_price"/>
                                            <field name="excluded_amount_discount"/>
                                            <field name="discount_amount"/>
                                            <field name="sale_price"/>
                                        </group>
                                    </form>
                                </field>
                            </group>
                        </page>
                        <page string="Installation Dates">
                            <field name="available_installation_line" nolabel="1" widget="one2many_list" mode="tree,kanban"
                                   readonly="1">
                                <tree editable="bottom" string="Installation Dates">
                                    <field name="crew_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="selected"/>
                                </tree>
                                <form string="Installation Dates">
                                    <group>
                                        <group>
                                            <field name="start_date"/>
                                            <field name="crew_id"/>
                                            <field name="selected"/>
                                        </group>
                                        <group>
                                            <field name="end_date"/>
                                            <field name="project_i360_id" attrs="{'invisible':[('project_i360_id', '=', False)]}"/>
                                            <field name="project_activity_i360_id" attrs="{'invisible':[('project_activity_i360_id', '=', False)]}"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Payment Info" name="payment_transaction" attrs="{'invisible': [('state', 'not in', ['sale', 'done'])]}">
                            <group>
                                <group string="Down Payment">
                                    <field name="promotion_code_id" readonly="1"/>
                                    <field name="stair_calc_based_on" readonly="1"/>
                                    <field name="calc_based_on" readonly="1"/>
                                    <field name="msrp_amount" readonly="1"/>
                                    <field name="additional_cost" readonly="1"/>
                                    <field name="one_year_price" readonly="1"/>
                                    <field name="excluded_amount_promotion" readonly="1"/>
                                    <field name="savings_amount" readonly="1"/>
                                    <field name="final_sale_price" readonly="1"/>
                                    <field name="payment_method" readonly="1"/>
                                    <field name="check_number" password="True" attrs="{'invisible': [('payment_method', '!=', 'check')]}" readonly="1"/>
                                    <field name="check_account_number" password="True" attrs="{'invisible': [('payment_method', '!=', 'check')]}" readonly="1"/>
                                    <field name="check_routing_number" password="True" attrs="{'invisible': [('payment_method', '!=', 'check')]}" readonly="1"/>
                                    <field name="down_payment_amount" readonly="1" />
                                </group>
                                <group string="Balance Due">
                                    <field name="balance_payment_method" readonly="1"/>
                                    <field name="balance_amount" readonly="1"/>
                                    <field name="deposit_amount" invisible="1"/>
                                    <field name="grand_amount_total" string="Sold Amount" readonly="1"/>
                                </group>
                                <group string="Finance">
                                    <field name="finance_option_id" readonly="1"/>
                                    <field name="finance_amount" readonly="1"/>
                                </group>
                                <group>
                                    <field name="monthly_promo" readonly="1"/>
                                    <field name="discount" invisible="1"/>
                                    <field name="adjustment" invisible="1"/>
                                    <field name="recision_date" readonly="1"/>
                                    <field name="cards" invisible="1"/>
                                </group>
                                <group string="Transaction Log" attrs="{'invisible': [('cards', '!=', True)]}">
                                    <field name="card_transaction_log_line" nolabel="1" readonly="1">
                                        <tree string="Transaction Log">
                                            <field name="name"/>
                                            <field name="state"/>
                                            <field name="message"/>
                                            <field name="error_code"/>
                                            <field name="void_transaction"/>
                                        </tree>
                                    </field>
                                </group>
                            </group>
                        </page>
                    </xpath>
                </data>
            </field>
        </record>

        <record model="ir.ui.menu" id="sale.menu_sale_invoicing">
            <field name="groups_id" eval="[(6,0,[ref('team_sale_contract.group_hidden_menu')])]"/>
        </record>

        <record model="ir.ui.menu" id="sale.product_menu_catalog">
            <field name="groups_id" eval="[(6,0,[ref('team_sale_contract.group_hidden_menu')])]"/>
        </record>

        <record model="ir.ui.menu" id="sale.res_partner_menu">
            <field name="groups_id" eval="[(6,0,[ref('team_sale_contract.group_hidden_menu')])]"/>
        </record>


    </data>
</odoo>