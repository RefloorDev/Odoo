<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_team_sale_contract" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.team_sale_contract</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale_management.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='quotation_order_setting_container']" position="after">
                <block title="Document Template" id="sale_document_template_id_setting">
                    <setting id="sale_contract_tmpl_id" string="Document Template" help="Select document template here.">
                        <field name="sale_contract_tmpl_id" options="{'no_create': True}"/>
                    </setting>
                    <setting id="sale_contract_tmpl_id_ncp" string="Document Template Without Co-Applicant" help="select document template without Co-Applicant here.">
                        <field name="sale_contract_tmpl_id_ncp" options="{'no_create': True}"/>
                    </setting>
                    <setting id="credit_application_tmpl_id" string="Document Template" help="select credit application document template here.">
                        <field name="credit_application_tmpl_id" options="{'no_create': True}"/>
                    </setting>
                    <setting id="credit_application_tmpl_id_ncp" string="Document Template Without Co-Applicant" help="select credit application document template Without Co-Applicant here.">
                        <field name="credit_application_tmpl_id_ncp" options="{'no_create': True}"/>
                    </setting>
                </block>
                <block title="Other Configuration" id="sale_other_data_id_setting">
                    <setting id="admin_fee" string="Admin Fee" help="Enter Admin fee here.">
                        <field name="admin_fee" options="{'no_create': True}"/>
                    </setting>
                    <setting id="min_sale_price" string="Minimum Sale Price" help="Minimum required sale/quote price for an order.">
                        <field name="min_sale_price" options="{'no_create': True}"/>
                    </setting>
                    <setting id="doc_status_message" string="Document Not Filled Message" help="Enter Message to Display while contract document not filled completely Here!">
                        <field name="doc_status_message" options="{'no_create': True}"/>
                    </setting>
                    <setting id="doc_completion_message" string="Completion Message" help="Enter Message to Display while contract document is filled completely Here!">
                        <field name="doc_completion_message" options="{'no_create': True}"/>
                    </setting>

                    <setting id="send_review_success_message" string="Review Link Sent Success Message" help="Enter Message to Display while sent review link is success!">
                        <field name="send_review_success_message" />
                    </setting>
                    <setting id="send_review_failure_message" string="Review Link Sent Failure Message" help="Enter Message to Display while sent review link is failed!">
                        <field name="send_review_failure_message"/>
                    </setting>

                    <setting id="max_no_transitions" string="Transition Limit" help="Maximum number of transitions allowed for a room.">
                        <field name="max_no_transitions" options="{'no_create': True}"/>
                    </setting>

                    <setting id="max_stair_width" string="Stair Width" help="Maximum width allowed for a stair.">
                        <field name="max_stair_width"/>
                    </setting>
                    <setting id="min_down_payment_amount" string="Down Payment" help="Minimum down payment required for a cash sale.">
                        <field name="min_down_payment_amount" options="{'no_create': True}"/>
                    </setting>

                    <setting id="payment_plan_id" string="Default Payment Plan" help="if no payment plan selected, this plan will send to i360.">
                        <field name="payment_plan_id" options="{'no_create': True}"/>
                    </setting>
                </block>
                <block title="API Configuration" id="sale_other_data_id_setting">
                    <setting id="enable_api_queue_system" string="Enable API Queueing System" help="Enable queueing system to prevent concurrent API requests.">
                        <field name="enable_api_queue_system" options="{'no_create': True}"/>
                    </setting>
                    <setting id="enable_additional_comment_api" string="Enable Additional Comments API" help="Enable separate API to sync Additional Comments to i360.">
                        <field name="enable_additional_comment_api" options="{'no_create': True}"/>
                    </setting>
                    <setting id="installer_date_range_limit" string="Installer Date Range" help="Maximum number of days from the appointment date to fetch available installation date.">
                        <field name="installer_date_range_limit" options="{'no_create': True}"/>
                    </setting>

                    <setting id="max_i360_sync_retry_limit" string="i360 Sync Retry Limit" help="Maximum allowed duration for i360 sync retry attempts from sync initiated time.">
                        <field name="max_i360_sync_retry_limit" options="{'no_create': True}"/>
                    </setting>

                    <setting id="geolocation_radius_limit" string="Geolocation Radius" help="Geolocation radius limit to determine arrival and departure time from the appointment venue.">
                        <field name="geolocation_radius_limit" options="{'no_create': True}"/>
                    </setting>
                    <setting id="enable_geolocation" string="Enable Geolocation Tracking" help="Enable geolocation tracking to get saleperson arrival and departure time in appointment venue.">
                        <field name="enable_geolocation" options="{'no_create': True}"/>
                    </setting>
                </block>
                <block title="Google API Configuration" id="sale_other_data_id_setting">
                    <setting id="google_auth_attachment_id" string="Auth File" help="File for Google service authentication for cloud storage">
                        <field name="google_auth_attachment_id" options="{'no_create': True}"/>
                    </setting>
                    <setting id="google_bucket_name" string="Google Storage" help="Google Storage Bucket Name.">
                        <field name="google_bucket_name" options="{'no_create': True}"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

    <record id="action_otl_sale_document_config_settings" model="ir.actions.act_window">
        <field name="name">Document Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_id" ref="res_config_settings_view_form_team_sale_contract"/>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'team_sale_contract', 'bin_size': False}</field>
    </record>
</odoo>
