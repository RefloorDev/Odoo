<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="appointment_result_form_view" model="ir.ui.view">
            <field name="name">appointment.result.form.view</field>
            <field name="model">appointment.result</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="result"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="last_available_screen"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="appointment_result_list_view" model="ir.ui.view">
            <field name="name">appointment.result.list.view</field>
            <field name="model">appointment.result</field>
            <field name="arch" type="xml">
                <list>
                    <field name="result"/>
                    <field name="last_available_screen"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="appointment_result_action_window" model="ir.actions.act_window">
            <field name="name">Appointment Result</field>
            <field name="res_model">appointment.result</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem 
            name="Appointment Result" parent="sale.menu_sale_config" 
            id="menu_act_appointment_result" action="appointment_result_action_window"/>
    </data>
</odoo>
