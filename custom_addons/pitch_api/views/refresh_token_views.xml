<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================================================================
         Refresh Token Views
         Manage device-bound refresh tokens for API sessions
    ==================================================================== -->

    <record id="view_pitch_api_refresh_token_list" model="ir.ui.view">
        <field name="name">auth.refresh.token.list</field>
        <field name="model">auth.refresh.token</field>
        <field name="arch" type="xml">
            <list string="API Devices" decoration-muted="revoked == True">
                <field name="user_id"/>
                <field name="device_id"/>
                <field name="device_name"/>
                <field name="ip_address"/>
                <field name="created_on"/>
                <field name="expires_on"/>
                <field name="last_used"/>
                <field name="use_count"/>
                <field name="revoked" widget="boolean"/>
                <field name="revocation_reason" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_pitch_api_refresh_token_form" model="ir.ui.view">
        <field name="name">auth.refresh.token.form</field>
        <field name="model">auth.refresh.token</field>
        <field name="arch" type="xml">
            <form string="API Device">
                <header>
                    <field name="revoked" widget="statusbar" statusbar_visible="False,True"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="device_name" placeholder="Device Name"/></h1>
                    </div>
                    <group>
                        <group string="Token Details">
                            <field name="user_id"/>
                            <field name="device_id"/>
                            <field name="token_family"/>
                        </group>
                        <group string="Client Information">
                            <field name="client_info"/>
                            <field name="ip_address"/>
                        </group>
                    </group>
                    <group>
                        <group string="Timestamps">
                            <field name="created_on"/>
                            <field name="expires_on"/>
                            <field name="last_used"/>
                        </group>
                        <group string="Usage &amp; Status">
                            <field name="use_count"/>
                            <field name="revoked"/>
                            <field name="revocation_reason" invisible="not revoked"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <!-- Backend views for managing refresh tokens (devices) -->
    <record id="action_pitch_api_refresh_tokens" model="ir.actions.act_window">
        <field name="name">API Devices</field>
        <field name="res_model">auth.refresh.token</field>
        <field name="view_mode">list,form</field>
        <field name="help">List of active refresh tokens (device sessions) for API clients.</field>
    </record>


    <!-- Menu item under Settings > Technical (or root Settings) -->
    <record id="menu_pitch_api_root" model="ir.ui.menu">
        <field name="name">Pitch API</field>
        <field name="sequence">8000</field>
        <field name="parent_id" ref="base.menu_custom"/>
    </record>

    <record id="menu_pitch_api_devices" model="ir.ui.menu">
        <field name="name">API Devices</field>
        <field name="parent_id" ref="menu_pitch_api_root"/>
        <field name="action" ref="action_pitch_api_refresh_tokens"/>
        <field name="sequence">10</field>
    </record>

</odoo>
