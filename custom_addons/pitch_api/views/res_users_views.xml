<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Add Pitch API flag to the user form -->
        <record id="view_pitch_api_res_users_form" model="ir.ui.view">
            <field name="name">res.users.pitch.form</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <!-- Insert the field into the Preferences page next to timezone -->
                <xpath expr="//page[@name='preferences']//group" position="inside">
                    <group string="Pitch API" colspan="2">
                        <field name="is_pitch_admin"/>
                    </group>
                </xpath>
            </field>
        </record>


        <!-- Read-only list view for Pitch API users (prevents create/edit/delete from the list) -->
        <record id="view_pitch_api_users_list" model="ir.ui.view">
            <field name="name">res.users.pitch.list</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <list string="Pitch API Users" create="false" edit="false" delete="false">
                    <field name="name" readonly="1"/>
                    <field name="login" readonly="1"/>
                    <field name="is_pitch_admin" readonly="1"/>
                    <field name="lang" readonly="1"/>
                    <field name="login_date" readonly="1"/>
                    <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                    <field name="state" widget="badge" readonly="1"
                        decoration-info="state == 'new'" decoration-success="state == 'active'"/>
                </list>
            </field>
        </record>

    <!-- Read-only form used when opening users from the Pitch Users menu. -->
        <record id="view_pitch_api_res_users_readonly_form" model="ir.ui.view">
            <field name="name">res.users.pitch.readonly.form</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <form string="User (Pitch API read-only)" create="false" edit="false" delete="false">
                    <sheet>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="login" readonly="1"/>
                            <field name="email" readonly="1"/>
                            <field name="is_pitch_admin" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_pitch_api_users" model="ir.actions.act_window">
            <field name="name">Pitch Admin Users</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,form</field>
            <!-- Use the protected list by default -->
            <field name="view_id" ref="view_pitch_api_users_list"/>
            <field name="domain">[("is_pitch_admin","=",True)]</field>
            <field name="help">List of users with Pitch API admin privileges.</field>
            <!-- Open the form in readonly mode when launched from this action -->
            <field name="context">{"form_view_initial_mode": "view"}</field>
        </record>

        <!-- Bind specific views to the Pitch API Users action so only this menu gets the readonly form -->
        <record id="action_pitch_api_users_view_list" model="ir.actions.act_window.view">
            <field name="act_window_id" ref="action_pitch_api_users"/>
            <field name="sequence" eval="0"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_pitch_api_users_list"/>
        </record>

        <record id="action_pitch_api_users_view_form" model="ir.actions.act_window.view">
            <field name="act_window_id" ref="action_pitch_api_users"/>
            <field name="sequence" eval="1"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_pitch_api_res_users_readonly_form"/>
        </record>

        <menuitem id="menu_pitch_api_users" name="Pitch Admin Users" parent="menu_pitch_api_root" action="action_pitch_api_users" sequence="30"/>

    </data>
</odoo>
