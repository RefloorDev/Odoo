<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_pitch_api_access_wizard" model="ir.ui.view">
            <field name="name">pitch.api.access.wizard.form</field>
            <field name="model">pitch.api.access.wizard</field>
            <field name="arch" type="xml">
                <form string="Grant Pitch API Admin Access" create="false" edit="false" delete="false">
                    <sheet>
                        <group>
                            <label for="user_ids" string="Select users to grant admin permission" />
                            <field name="user_ids" widget="many2many_tags" domain="[('active','=',True), ('share','=',False), ('is_pitch_admin','=',False)]" 
                            options="{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_grant_access" type="object" string="Grant Admin Access" class="btn-primary"/>
                        <button string="Cancel" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_pitch_api_access_wizard" model="ir.actions.act_window">
            <field name="name">Grant Pitch API Admin Access</field>
            <field name="res_model">pitch.api.access.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_pitch_api_access_wizard"/>
            <!-- <field name="target">current</field> -->
            <field name="target">new</field>
            <field name="context">{}</field>
        </record>

        <!-- Wizard menu disabled - grant is_pitch_admin directly in user form -->
        <menuitem id="menu_pitch_api_grant_access" name="Grant Admin Access" parent="menu_pitch_api_root" action="action_pitch_api_access_wizard" sequence="25"/>
    </data>
</odoo>
