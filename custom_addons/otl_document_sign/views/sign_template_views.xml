<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Signature Request Template Views -->
    <record id="sign_template_view_kanban" model="ir.ui.view">
        <field name="name">otl_document_sign.template.kanban</field>
        <field name="model">otl_document_sign.template</field>
        <field name="arch" type="xml">
            <!-- <kanban create="false" quick_create="false" class="o_kanban_dashboard o_kanban_sign_template" js_class="otl_document_sign.document_sign_kanban_renderer"> -->
            <kanban create="false" quick_create="false" class="o_kanban_dashboard o_kanban_sign_template">
                <field name="active"/>
                <field name="attachment_id"/>
                <field name="color"/>
                <field name="create_date"/>
                <field name="favorited_ids"/>
                <field name="responsible_count"/>
                <field name="create_uid"/>
                <field name="display_name"/>
                <field name="tag_ids"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex">
                            <field name="display_name" class="fw-bold fs-5"/>
                            <!-- <field name="active" widget="label_selection"
                                options="{'classes': {'True': 'success', 'False': 'danger'}}"
                                class="ms-auto"/> -->
                        </div>
                        <!-- <div class="mb-2">
                            <field name="attachment_id"/>
                        </div> -->
                        <div>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </div>
                        <div class="row mt-2">
                            <div>
                                <i class="fa fa-calendar" role="img" aria-label="Created" title="Created"/>
                                <span class="mx-1"></span>
                                <field name="create_date"/>
                            </div>
                            <!-- <div class="col-6 text-end">
                                <field name="create_uid" widget="image" preview_image="avatar_128" options="{'size': [32, 32]}" class="rounded-circle o_kanban_avatar" />
                            </div> -->
                        </div>
                        <!-- <div>
                            <t t-component="BadgeComponent" text="'High Priority'" color="'badge-danger'"/>
                        </div> -->

                        <div>
                            <div class="my_badge_placeholder"></div> <!-- Placeholder for mounting Badge -->
                        </div>
                        <div class="row mt-2">
                            <div class="col-12 d-flex gap-2">
                                <!-- <button name="action_sign_document_send_request" string="Generate" type="object" class="oe_highlight"/> -->
                                <button name="%(otl_document_sign.action_sign_send_request)d" type="action"
                                        class="btn btn-primary btn-sm"
                                        context="{'sign_directly_without_mail': 0,'send_button':'send_button'}">
                                    Send
                                </button>
                                <button name="%(otl_document_sign.action_sign_send_request)d" type="action"
                                        class="btn btn-primary btn-sm"
                                        context="{'sign_directly_without_mail': 1,'sign_now_button':'sign_now_button'}">
                                    Sign Now
                                </button>
                                <button name="%(otl_document_sign.action_sign_template_share)d" type="action"
                                        class="btn btn-outline-secondary btn-sm"
                                        invisible="responsible_count &gt; 1">
                                    Share
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="sign_template_view_tree" model="ir.ui.view">
        <field name="name">otl_document_sign.template.tree</field>
        <field name="model">otl_document_sign.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="attachment_id"/>
                <field name="create_date"/>
                <field name="sign_item_ids"/>
            </list>
        </field>
    </record>

    <record id="sign_template_view_form" model="ir.ui.view">
        <field name="name">otl_document_sign.template.form</field>
        <field name="model">otl_document_sign.template</field>
        <field name="arch" type="xml">
            <form create="false">
                <header>
                    <button name="%(otl_document_sign.action_sign_send_request)d" string="Send" type="action" class="oe_highlight" context="{'sign_directly_without_mail': 0}"/>
                    <button name="%(otl_document_sign.action_sign_template_share)d" string="Share" type="action" invisible="responsible_count > 1"/>
                    <button name="%(otl_document_sign.action_sign_template_share)d" string="Share" type="action" invisible="responsible_count > 1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button string="Edit fields" icon="fa-wrench" type="object" name="go_to_custom_template" class="oe_stat_button"/>
                    </div>
                    <widget name="web_ribbon" text="Archived" bg_color="bg-danger" invisible="active == True"/>
                    <div class="oe_title">
                        <h1>
                            <div class="o_row">
                                <field name="name"  placeholder="Name of the file" nolabel="1"/>
                            </div>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="attachment_id" invisible="1"/>
                            <field name="responsible_count" invisible="1"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" placeholder="Tags"/>
                            <field name="redirect_url" widget="url"/>
                            <field name="redirect_url_text" invisible="redirect_url == ''"/>
                            <field name="privacy"/>
                            <field name="favorited_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Document">
                            <field name="datas" widget="pdf_viewer"/>
                        </page>
                        <page string="Signatures" groups="base.group_no_one">
                            <label for="sign_item_ids"/>
                            <field name="sign_item_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sign_template_view_search" model="ir.ui.view">
        <field name="name">otl_document_sign.template.search</field>
        <field name="model">otl_document_sign.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="attachment_id" string="Document Name"/>
                <field name="tag_ids"/>
                <filter name="my_templates" string="My Templates" domain="[('create_uid', '=', uid)]"/>
                <filter name="favorite" string="My Favorites" domain="[('favorited_ids', '=', uid)]"/>
                <separator/>
                <filter name="archive" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="sign_template_action" model="ir.actions.act_window">
        <field name="name">Choose a Template</field>
        <field name="res_model">otl_document_sign.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="sign_template_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Upload a PDF
            </p><p>
                Or, <a href="/web#action=otl_document_sign.sign_template_with_archived_action">load our templates of contract</a>.
            </p>
        </field>
    </record>

    <record id="sign_template_with_archived_action" model="ir.actions.act_window">
        <field name="name">Choose a Template</field>
        <field name="res_model">otl_document_sign.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="sign_template_view_search"/>
        <field name="context" eval="{'search_default_archive': 1}"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Upload a PDF</p>
        </field>
    </record>

    <!-- Signature Item Views -->
    <record id="sign_item_view_tree" model="ir.ui.view">
        <field name="name">otl_document_sign.item.tree</field>
        <field name="model">otl_document_sign.item</field>
        <field name="arch" type="xml">
            <list default_order="page,posY,posX,id" editable="bottom">
                <field name="type_id"/>
                <field name="required"/>
                <field name="responsible_id"/>
                <field name="page"/>
                <field name="posX"/>
                <field name="posY"/>
                <field name="width"/>
                <field name="height"/>
            </list>
        </field>
    </record>

    <record id="sign_item_view_form" model="ir.ui.view">
        <field name="name">otl_document_sign.item.form</field>
        <field name="model">otl_document_sign.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Information">
                            <field name="type_id"/>
                            <field name="required"/>
                            <field name="responsible_id"/>
                        </group>

                        <group string="Display">
                            <field name="page"/>
                            <field name="posX"/>
                            <field name="posY"/>
                            <field name="width"/>
                            <field name="height"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Signature Item Type Views -->
    <record id="sign_item_type_view_tree" model="ir.ui.view">
        <field name="name">otl_document_sign.item.type.tree</field>
        <field name="model">otl_document_sign.item.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="item_type"/>
                <field name="auto_field"/>
                <field name="model_id"/>
            </list>
        </field>
    </record>

    <record id="sign_item_type_view_form" model="ir.ui.view">
        <field name="name">otl_document_sign.item.type.form</field>
        <field name="model">otl_document_sign.item.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="item_type"/>
                        <field name="auto_field"/>
                    </group>
                    <group>
                        <group>
                            <label for="default_width"/>
                            <div class="o_row">
                                <field name="default_width"/>
                                <span>(1.0 = full page size)</span>
                            </div>

                            <label for="default_height"/>
                            <div class="o_row">
                                <field name="default_height"/>
                                <span>(1.0 = full page size)</span>
                            </div>
                        </group>
                        <group>
                            <field name="tip"/>
                            <field name="placeholder"/>
                            <field name="option_field"/>
                            <field name="model_id" options="{'no_create_edit': True, 'no_open':True,'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sign_item_type_action" model="ir.actions.act_window">
        <field name="name">Signature Item Type</field>
        <field name="res_model">otl_document_sign.item.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Signature Item Party Views -->
    <record id="sign_item_role_view_tree" model="ir.ui.view">
        <field name="name">otl_document_sign.item.role.tree</field>
        <field name="model">otl_document_sign.item.role</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name" string="Role Name"/>
                <field name="sms_authentification"/>
            </list>
        </field>
    </record>

    <record id="sign_item_role_view_form" model="ir.ui.view">
        <field name="name">otl_document_sign.item.role.form</field>
        <field name="model">otl_document_sign.item.role</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="sms_authentification"/>
                        <button type="object" name="buy_credits" string="Buy SMS credit" class="btn-primary"></button>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sign_item_role_action" model="ir.actions.act_window">
        <field name="name">Signature Item Role</field>
        <field name="res_model">otl_document_sign.item.role</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- Menus -->
    <menuitem id="menu_document" name="Sign" web_icon="otl_document_sign,static/description/icon.png" groups="otl_document_sign.group_sign_user"/>
    <menuitem id="otl_document_sign.sign_template_menu" name="Templates" parent="otl_document_sign.menu_document" action="sign_template_action" sequence="10" />
    <menuitem id="sign_request_menu" name="Signatures" parent="menu_document" action="sign_request_action" groups="otl_document_sign.group_sign_user" sequence="20"/>
    <menuitem id="menu_sign_configuration" sequence="100" name="Configuration" parent="menu_document"/>
    <!-- Menus -->
    <menuitem id="otl_document_sign.sign_item_type_menu" name="Field Types" parent="otl_document_sign.menu_sign_configuration" action="sign_item_type_action" groups="base.group_no_one"/>
    <menuitem id="otl_document_sign.sign_item_role_menu" name="Roles" parent="otl_document_sign.menu_sign_configuration" action="sign_item_role_action" groups="otl_document_sign.group_sign_manager"/>
    <menuitem id="sign_request_item_menu" name="Signature Requests Items" parent="menu_sign_configuration" action="sign_request_item_action" groups="base.group_no_one" sequence="30"/>






</odoo>
