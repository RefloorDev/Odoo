<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="sign_log_view_tree" model="ir.ui.view">
        <field name="name">otl_document_sign.log.tree</field>
        <field name="model">otl_document_sign.log</field>
        <field name="arch" type="xml">
            <list string="Logs">
                <field name="log_date"/>
                <field name="action"/>
                <field name="partner_id"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="ip"/>
                <!-- who can acces what ?? groups on the fields for the moment -->
                <field name="request_state" optional="hide"/>
            </list>
        </field>
    </record>
</odoo>
