<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.digest</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='access_rights']" position="before">
                <setting id="default_tz" string="Default Timezone" help=" Default Timezone to be set while creating New Partners &amp; Customers.">
                    <field name="default_tz" options="{'no_create': True}"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
