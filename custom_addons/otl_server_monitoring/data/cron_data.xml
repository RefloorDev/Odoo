<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="server_monitoring_log_cron" forcecreate='True' model="ir.cron">
            <field name="name">Get Server Monitoring Logs</field>
            <field eval="True" name="active"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="model_id" ref="otl_server_monitoring.model_otl_server_monitoring_log"/>
            <field name="state">code</field>
            <field name="code">model.cron_get_server_monitoring_logs()</field>
        </record>

    </data>
</odoo>