<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="team_customer_appointment_form_view_inherited" model="ir.ui.view">
            <field name="name">team.customer.appointment.form</field>
            <field name="model">team.customer.appointment</field>
            <field name="inherit_id" ref="team_sale_contract.team_customer_appointment_form_view"/>
            <field name="arch" type="xml">
                <field name="appointment_date" position="after">
                    <field name="improveit_appointment_id" readonly="1"/>
                    <field name="completed_date" invisible="0"/>
                </field>
            </field>
        </record>

        <record id="team_customer_appointment_tree_view" model="ir.ui.view">
            <field name="name">team.customer.appointment.tree</field>
            <field name="model">team.customer.appointment</field>
            <field name="inherit_id" ref="team_sale_contract.team_customer_appointment_tree_view"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="improveit_appointment_id" readonly="1"/>
                </field>
            </field>
        </record>
    
    </data>
</odoo>
